# Mock Mode (set to "true" for development without API keys)
MOCK_MODE="false"

# Google Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Shopify API (myshopify.com URLを使用)
SHOPIFY_STORE_URL="YOUR_STORE.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN="YOUR_STOREFRONT_TOKEN"
SHOPIFY_ADMIN_API_ACCESS_TOKEN="shpat_YOUR_ADMIN_TOKEN"

# Shopify App credentials (Admin APIトークン自動更新に使用)
SHOPIFY_CLIENT_ID="YOUR_CLIENT_ID"
SHOPIFY_CLIENT_SECRET="shpss_YOUR_CLIENT_SECRET"

# Backend API URL (フロントエンドから接続するバックエンドのURL)
NEXT_PUBLIC_API_URL="http://localhost:8000"

