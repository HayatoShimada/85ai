# Mock Mode (set to "true" for development without API keys)
MOCK_MODE="false"

# Google Gemini API
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Shopify API (myshopify.com URLを使用)
SHOPIFY_STORE_URL="YOUR_STORE.myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN="YOUR_STOREFRONT_TOKEN"
SHOPIFY_ADMIN_API_ACCESS_TOKEN="shpat_YOUR_ADMIN_TOKEN"

# Shopify App credentials (Admin APIトークン自動更新に使用)
SHOPIFY_CLIENT_ID="YOUR_CLIENT_ID"
SHOPIFY_CLIENT_SECRET="shpss_YOUR_CLIENT_SECRET"

# Backend API URL (フロントエンドから接続するバックエンドのURL)
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Mirror Camera Settings
MIRROR_CAMERA_INDEX="0"
MIRROR_WIDTH="1920"
MIRROR_HEIGHT="1080"
MIRROR_FPS="30"
MIRROR_SEGMENTER="auto"       # auto / vision / mediapipe
MIRROR_VISION_QUALITY="2"     # 0=fast(GPU) / 1=balanced(GPU+NE) / 2=accurate(NeuralEngine)
MIRROR_SEG_WIDTH="640"        # MediaPipe用セグメンテーション内部解像度 (幅)
MIRROR_WEBP_QUALITY="80"      # WebP出力品質 (0-100)
MIRROR_MASK_BLUR="7"          # マスクエッジのぼかし (0=なし, 奇数)
MIRROR_MASK_THRESHOLD="0.5"   # マスク閾値 (0.0-1.0)

